  "type": "module",
  "scripts": {
    "preinstall": "node -e \"if (!/pnpm/.test(process.env.npm_config_user_agent || '')) { console.error('This project uses pnpm only. Do not use npm.'); process.exit(1); }\"",
    "dev": "vite build --watch",
    "lint": "node scripts/lint-architecture.mjs",
    "typecheck": "node scripts/typecheck-contracts.mjs",
    "smoke": "node scripts/smoke-theme.mjs",
    "smoke:playwright": "node scripts/smoke-playwright.mjs",
    "audit:real-pages": "node scripts/audit-real-pages.mjs",
    "audit:notification-motion": "node scripts/qa/notification-motion-audit.mjs",
    "verify:notification-center": "node scripts/verify-notification-center.mjs",
    "verify:docsme": "node scripts/verify-docsme.mjs",
    "verify:douban-adaptation": "node scripts/verify-douban-adaptation.mjs",
    "verify:link-submit": "node scripts/verify-link-submit-adaptation.mjs",
    "verify:photos-pagination": "node scripts/verify-photos-pagination.mjs",
    "verify:plugin-inventory": "node scripts/verify-plugin-inventory.mjs",
    "verify:plugin-runtime": "node scripts/verify-plugin-runtime-compat.mjs",
    "verify:plugins:live": "node scripts/verify-injected-plugin-lifecycle.mjs",
    "verify:plugins:all": "node scripts/verify-all-plugins.mjs",
    "verify:seo-contract": "node scripts/verify-seo-contract.mjs",
    "verify:shiki-adaptation": "node scripts/verify-shiki-adaptation.mjs",
    "verify:steam-adaptation": "node scripts/verify-steam-adaptation.mjs",
    "verify:waterfall-lifecycle": "node scripts/verify-waterfall-lifecycle.mjs",
    "verify:moments": "node scripts/verify-moments.mjs",
    "verify:reload": "node scripts/verify-theme-reload.mjs",
    "audit:licenses": "node scripts/audit-dependency-policy.mjs",
    "audit:security": "node scripts/audit-dependencies.mjs",
    "audit:dependencies": "pnpm run audit:licenses && pnpm run audit:security",
    "audit:plugins": "node scripts/audit-plugin-inventory.mjs",
    "audit:plugins:strict": "node scripts/audit-plugin-inventory.mjs --strict-theme",
    "notices:generate": "node scripts/generate-third-party-notices.mjs",
    "notices:check": "node scripts/generate-third-party-notices.mjs --check && node scripts/check-third-party-notices.mjs",
    "verify:contracts": "node scripts/verify-weather-runtime.mjs && node scripts/verify-shell-bootstrap-contract.mjs && node scripts/verify-window-lifecycle.mjs && node scripts/verify-media-performance-contract.mjs && node scripts/verify-lazy-comment-lifecycle.mjs && node scripts/verify-shell-resource-lifecycle.mjs && node scripts/verify-pnpm-supply-chain-policy.mjs && node scripts/verify-widgets-config-schema.mjs && node scripts/verify-widget-bangumis.mjs && node scripts/verify-widget-photos.mjs && node scripts/verify-widget-steam.mjs && pnpm run verify:plugin-inventory && pnpm run verify:douban-adaptation && pnpm run verify:photos-pagination && pnpm run verify:waterfall-lifecycle && pnpm run verify:steam-adaptation && pnpm run verify:link-submit && pnpm run verify:plugin-runtime",
    "verify:performance": "node scripts/verify-html-performance.mjs",
    "verify:pjax-lifecycle": "node scripts/verify-pjax-lifecycle.mjs",
    "verify:release-package": "node scripts/verify-release-package.mjs",
    "verify:halo-compat:prepare": "node scripts/prepare-halo-compat.mjs",
    "check": "node scripts/lint-architecture.mjs && node scripts/typecheck-contracts.mjs && pnpm run verify:contracts && pnpm run notices:check && vite build && node scripts/smoke-theme.mjs",
    "build-only": "vite build",
    "build": "vite build && pnpm run package",
    "package": "theme-package && node scripts/finalize-theme-package.mjs"
  },
  "devDependencies": {
    "@alpinejs/intersect": "3.15.12",
    "@alpinejs/morph": "3.15.12",
    "@halo-dev/theme-package-cli": "1.1.1",
    "@iconify-json/lucide": "1.2.118",
    "@iconify/tailwind4": "1.2.3",
    "@tailwindcss/vite": "4.3.3",
    "alpinejs": "3.15.12",
    "esbuild": "0.28.1",
    "playwright": "1.61.1",
    "tailwindcss": "4.3.3",
    "vite": "8.1.5"
  },
  "dependencies": {
    "nprogress": "0.2.0",
    "pjax": "0.2.8",
    "qrcode": "1.5.4"
  }
